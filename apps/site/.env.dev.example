# apps/site/.env.dev.example
#
# Local dev defaults for the Next.js landing. No auth required here
# (landing has a CTA to the web app, no signed-in flows).

NEXT_PUBLIC_APP_NAME=Fxl Finders
NEXT_PUBLIC_WEB_URL=http://localhost:8006

# --- Analytics: disabled in dev ---
NEXT_PUBLIC_VERCEL_ANALYTICS=

# --- Phase 04: /r/[code] referral redirect (Node runtime; backend-only) ---
# DATABASE_URL is backend-only — NEVER VITE_-prefixed. Same Postgres as apps/api,
# connecting as the fxl_finders_app runtime role (RLS enforced; the public code
# lookup works via the referral_links_public_lookup policy).
DATABASE_URL=postgresql://fxl_finders_app:fxl_finders_app@localhost:5006/fxl_finders
# Secret for the daily-rotating IP-hash salt (privacy). Backend-only.
HASH_SALT_SECRET=dev_hash_salt_change_me

# --- Upstash Ratelimit (optional in local dev) ---
# RATE_LIMIT_ENABLED=false makes the /r limiter a no-op without Upstash creds.
RATE_LIMIT_ENABLED=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
