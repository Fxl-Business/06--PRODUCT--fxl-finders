# apps/mobile/.env.dev.example
#
# Local dev defaults for Expo. Committed because it only contains the
# FXL Local Sandbox publishable key.
#
# NOTE: Clerk on native (iOS/Android) requires a dev build for the full
# sign-in flow. Expo Go works for layout, but for end-to-end auth run
# `pnpm ios` or `pnpm android` (requires Xcode / Android Studio).

EXPO_PUBLIC_API_URL=http://localhost:3006

# --- Auth: FXL Local Sandbox (shared) ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_FXL_LOCAL_SANDBOX_REPLACE_ME
