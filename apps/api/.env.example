# --- Server ---
NODE_ENV=development
PORT=3006
CORS_ORIGIN=http://localhost:8006

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5006/fxl_finders

# --- Auth (Clerk) ---
# Get keys from https://dashboard.clerk.com/
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Clerk webhook signing secret (Phase 05): Clerk Dashboard → Webhooks → POST
# /api/v1/webhooks/clerk → Signing Secret (whsec_...). Backfills sellers.clerk_user_id.
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Email (optional, Resend) ---
RESEND_API_KEY=
RESEND_FROM=
